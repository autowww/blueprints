# Foundational automation image — extend for Playwright, Python, or cloud CLIs.
# Build: docker compose -f blueprints/agents/docker/compose.yaml build

FROM node:20-bookworm-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    jq \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /work

# For Playwright (browser/Electron deps), use docker/Dockerfile.playwright and service agent-playwright
# in compose.yaml instead of bloating this default image.

ENV NODE_ENV=production
