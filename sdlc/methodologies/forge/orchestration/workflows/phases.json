{
  "schema_version": "1",
  "title": "Forge SDLC phase orchestration descriptors",
  "precedence_note": "External compliance and org-mandated controls may override orchestration recommendations; see forge/standards/precedence.md",
  "phases": [
    {
      "id": "forge.phase.A.discover",
      "letter": "A",
      "name": "Discover",
      "forge_expression": "Ore intake; discover: Sparks",
      "triggers": ["new_ore", "retro_new_ore", "intake_ceremony"],
      "entry_conditions": ["raw_intent_captured", "hat_declared_if_solo"],
      "standards_checks": ["l1_data_class_unknown_then_compliance_early"],
      "parallel_criteria": ["product_lenses_on_different_facets_of_same_ore", "cross_cutting_with_product_if_merge_before_ingot"],
      "sequential_criteria": ["compliance_in_scope_before_marketing_claims_regulated"],
      "merge_rules": "versona_family_product_or_pm_summary; cross_cutting_concerns_listed_not_overruled",
      "escalation_rules": ["ore_too_large_split", "legal_blocker_bank_and_counsel"],
      "trace_outputs": ["ore_record", "versona_session_outputs_optional", "ember_log_if_scope_accepted"],
      "suggested_routing_hint": "versona_all_optional_then_product_and_cross_cutting"
    },
    {
      "id": "forge.phase.B.specify",
      "letter": "B",
      "name": "Specify",
      "forge_expression": "Ore → Ingot; specify: Sparks",
      "triggers": ["refinement_ceremony", "specify_spark"],
      "entry_conditions": ["ore_triaged", "acceptance_path_visible"],
      "standards_checks": ["compliance_dpia_lawful_basis", "security_data_flows"],
      "parallel_criteria": ["ba_pm_architecture_sketch_after_problem_statement_shared"],
      "sequential_criteria": ["ba_acceptance_shape_before_architecture_nfr_same_ingot"],
      "merge_rules": "ingot_owner_product_hat_consolidates; versona_pm_if_delivery_dependency_conflict",
      "escalation_rules": ["ac_disagreement_rework_ingot"],
      "trace_outputs": ["ingot_doc", "section5_artifacts", "ember_log_on_ac_cuts"],
      "suggested_routing_hint": "ba_architecture_pm_compliance_security_as_needed"
    },
    {
      "id": "forge.phase.C.design",
      "letter": "C",
      "name": "Design",
      "forge_expression": "Ingot → Sparks; design: Sparks; ADRs",
      "triggers": ["planning_technical_decomposition", "design_spark"],
      "entry_conditions": ["ingot_ready_for_decomposition"],
      "standards_checks": ["security_threat_assumptions", "compliance_design_time_controls"],
      "parallel_criteria": ["architecture_data_se_on_distinct_sparks"],
      "sequential_criteria": ["architecture_system_shape_before_se_module_same_spark"],
      "merge_rules": "versona_family_engineering_if_full_stack_unclear_else_lead_engineer",
      "escalation_rules": ["architecture_split_ember_log_assay_design_checkpoint_optional"],
      "trace_outputs": ["adr_links_on_sparks", "design_session_outputs"],
      "suggested_routing_hint": "architecture_first_then_specialists"
    },
    {
      "id": "forge.phase.D.build_charge",
      "letter": "D",
      "name": "Build_Charge",
      "forge_expression": "Charge execution; build: Sparks; C3 daily sync",
      "triggers": ["daily_charge", "build_spark", "c3_sync"],
      "entry_conditions": ["spark_in_charge", "dod_understood"],
      "standards_checks": ["org_coding_baseline", "agentic_coding_when_ai_assisted"],
      "parallel_criteria": ["se_testing_devops_distinct_concerns_same_spark_merge_in_review_or_ci"],
      "sequential_criteria": ["se_before_testing_signoff_same_changeset_typical"],
      "merge_rules": "implementer_merges_code; testing_section5_feeds_verify",
      "escalation_rules": ["blocked_vs_banked_per_process_and_flows"],
      "trace_outputs": ["prs", "ci_logs", "session_notes"],
      "suggested_routing_hint": "se_testing_devops_by_stack"
    },
    {
      "id": "forge.phase.E.verify",
      "letter": "E",
      "name": "Verify",
      "forge_expression": "Assay prep; verify: Sparks; review",
      "triggers": ["review_ceremony", "assay_prep", "verify_spark"],
      "entry_conditions": ["build_artifacts_available", "test_plan_aligned"],
      "standards_checks": ["compliance_evidence_pack", "security_release_review_gates"],
      "parallel_criteria": ["testing_security_compliance_parallel_on_release_candidate_merge_at_assay"],
      "sequential_criteria": ["testing_must_fix_before_security_final_same_build"],
      "merge_rules": "governance_hat_or_versona_pm_assay_readiness_table",
      "escalation_rules": ["critical_rework_or_proceed_with_conditions_dated_followup_sparks"],
      "trace_outputs": ["evidence_pack_links", "assay_record"],
      "suggested_routing_hint": "testing_security_compliance_pm"
    },
    {
      "id": "forge.phase.F.release",
      "letter": "F",
      "name": "Release",
      "forge_expression": "Assay pass → ship; release: Sparks",
      "triggers": ["assay_gate_pass", "release_spark", "ship_checklist"],
      "entry_conditions": ["phase_E_complete_for_work_type"],
      "standards_checks": ["l1_l2_release_controls", "customer_comms_if_contractual"],
      "parallel_criteria": ["devops_marketing_cs_parallel_after_assay_decision"],
      "sequential_criteria": ["assay_decision_before_prod_promotion"],
      "merge_rules": "governance_release_manager_go_no_go_narrative",
      "escalation_rules": ["emergency_bypass_explicit_waiver_ember_log"],
      "trace_outputs": ["release_notes", "tags", "ember_log", "learning_to_ore"],
      "suggested_routing_hint": "devops_pm_marketing_cs"
    }
  ]
}
